# =====================================
# slskd API
# =====================================

# Local slskd example:
# SLSKD_API_URL=http://localhost:5030/api/v0
# LAN server example:
# SLSKD_API_URL=http://192.168.1.100:5030/api/v0
# Domain / reverse proxy example:
# SLSKD_API_URL=https://soulseek.example.com/api/v0
SLSKD_API_URL=http://localhost:5030/api/v0
SLSKD_API_KEY=YOUR_SLSKD_API_KEY

# =====================================
# General
# =====================================

DRY_RUN=false
DEBUG_REJECTED=false
MAX_TRACKS=50

# =====================================
# Search
# =====================================

SEARCH_WAIT_SECONDS=10
TRACK_SEARCH_TIMEOUT_SECONDS=120

# These options may be used by newer/advanced builds.
# Keeping them here is safe, but the current release may ignore some of them.
SEARCH_RESULT_LIMIT=15
MAX_CANDIDATE_SCAN=40
SEARCH_RESPONSE_RETRY_ATTEMPTS=6
SEARCH_RESPONSE_RETRY_DELAY_SECONDS=5
SEARCH_RESPONSE_API_TIMEOUT_SECONDS=8
SEARCH_FALLBACK_PLAIN=true
FIRST_PASS_ACCEPTED_EARLY_STOP=true
STRICT_CANDIDATE_MATCHING=true
REJECT_BAD_VERSION_KEYWORDS=true
REJECT_UNEXPECTED_EXTRA_TITLE_WORDS=true

# =====================================
# Audio quality
# =====================================

MIN_GOOD_MP3_SIZE=2500000
ALLOW_UNKNOWN_BITRATE_MP3=true

# =====================================
# Download verification
# =====================================

DOWNLOAD_RETRY_CANDIDATES=10
DOWNLOAD_VERIFY_WAIT_SECONDS=60
DOWNLOAD_VERIFY_INTERVAL_SECONDS=2
DOWNLOAD_WAIT_SECONDS=0

# These options may be used by newer/advanced builds.
FAST_FAIL_REJECTED_TRANSFERS=true
DOWNLOAD_STATUS_POLL_SECONDS=2

# =====================================
# API behavior
# =====================================

API_TIMEOUT_SECONDS=30
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY_SECONDS=3

# =====================================
# Artwork
# =====================================

# These options may be used by newer/advanced builds.
ARTWORK_SOURCE=itunes
ARTWORK_FAST_MODE=true
ARTWORK_REPLACE_EXISTING=true
ARTWORK_IMAGE_SIZE=600
ARTWORK_ITUNES_LIMIT=8
ARTWORK_LOOKUP_TIMEOUT_SECONDS=5
ARTWORK_IMAGE_TIMEOUT_SECONDS=8
ARTWORK_PREFETCH_PARALLEL_DOWNLOADS=6
ARTWORK_MUSICBRAINZ_SEARCH_ON_MISSING_MBID=false

# =====================================
# Paths
# =====================================

SLSKD_DOWNLOADS_PATH=./downloads
FINAL_MUSIC_PATH=./music

# =====================================
# Cleanup
# =====================================

# This option may be used by newer/advanced builds.
CLEANUP_RUN_STAGING=true
